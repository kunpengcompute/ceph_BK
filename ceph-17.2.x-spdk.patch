     print(json.dumps(ls, indent=4))
 
 
+@infer_fsid
+@infer_image
+def create_spdk_osd(ctx) -> int:
+    if 'fsid' not in ctx :
+        print('please start ceph cluster first.')
+        return 0
+    # get image name with hash
+    container_info = get_container_info(ctx, 'crash', False)
+    if not container_info:
+        print('please start ceph cluster first.')
+        return 0
+    if len(ctx._args.command) != 1:
+        print('No legal command is provided, init deploy or create. e.g., cephadm spdkosd --b osd.yaml create')
+        return -1
+    command = ctx._args.command[0]
+
+    # ceph default route is: /var/lib/ceph/{fsid}
+    cephVarLibPath='{}/{}'.format(ctx._conf.data_dir, ctx.fsid)
+
+    ret = 0
+    if 'init' == command:
+        ret = spdk_osd_init(ctx, cephVarLibPath, container_info.image_name)
+        if ret < 0:
+            return ret
+    elif 'deploy' == command:
+        spdk_osd_deploy(ctx, cephVarLibPath, ctx.fsid)
+    elif 'create' == command:
+        ret = spdk_osd_init(ctx, cephVarLibPath, container_info.image_name)
+        if ret < 0:
+            return ret
+        spdk_osd_deploy(ctx, cephVarLibPath, ctx.fsid)
+    else:
+        print('No legal command is provided. use: cephadm spdkosd init/deploy/create')
+    return ret
+
+def spdk_osd_init(ctx, cephVarLibPath, imageName):
+    create_hugepages_file = f"{cephVarLibPath}/tmp/created_hugepage.sh"
+    create_hugepages_file_content = '''
+echo "create hugepages..."
+numa_num=$(lscpu | grep "NUMA node(s)" | awk '{print $3}')
+for ((i=0;i<$numa_num;i++))
+do
+        echo 20480 > /sys/devices/system/node/node$i/hugepages/hugepages-2048kB/nr_hugepages
+done
+
+cat /proc/mounts | grep huge
+'''
+    write_code_to_file(create_hugepages_file, create_hugepages_file_content)
+
+
+    ceph_osd_keyring_file = '{}/tmp/ceph_osd.keyring'.format(cephVarLibPath)
+    commandline="cephadm shell ceph auth get client.bootstrap-osd"
+    out, err, code = call(ctx, commandline.split( ),
+        verbosity=CallVerbosity.DEBUG)
+    ceph_osd_keyring_file_content = out
+    write_code_to_file(ceph_osd_keyring_file, ceph_osd_keyring_file_content)
+
+
+    commandline="cephadm shell ceph config generate-minimal-conf"
+    out, err, code = call(ctx, commandline.split( ),
+        verbosity=CallVerbosity.DEBUG)
+    ceph_global_config = out
+
+    if ctx.c:
+        custom_ext_config = read_file_content(ctx.c)
+        custom_ext_config = custom_ext_config.replace("[global]", "")
+        ceph_osd_config = '''
+{ceph_global_config}
+{custom_ext_config}
+'''.format(ceph_global_config=ceph_global_config, custom_ext_config=custom_ext_config)
+    else :
+        ceph_osd_config = '''
+{ceph_global_config}
+bluestore_block_db_path = ""
+bluestore_block_db_size = 0
+bluestore_block_wal_path = ""
+bluestore_block_wal_size = 0
+'''.format(ceph_global_config=ceph_global_config)
+
+    bdfs_list=getbdfs(ctx, ctx.bstr, ctx.b)
+    only_osd_config = ""
+    loopnum = len(bdfs_list)
+    if loopnum == 0:
+        print('no avaliable device to deploy OSD')
+        return -3
+
+    logger.debug(f"start osd with config: {bdfs_list}")
+    for item in bdfs_list:
+        thisbdfs=item['bdfs']
+        osd_id= item['osd_id']
+        only_osd_config ='''
+{only_osd_config}
+[osd.{osd_id}]
+bluestore_block_path = spdk:trtype:pcie traddr:{thisbdfs}
+
+'''.format(osd_id=osd_id, thisbdfs=thisbdfs, only_osd_config=only_osd_config)
+
+    ceph_osdN_config = f"{ceph_osd_config}{only_osd_config}"
+    write_code_to_file('{}/tmp/ceph.conf.with.osdN.for.create.osd'.format(cephVarLibPath), ceph_osdN_config)
+    write_code_to_file('{}/tmp/ceph.config.for.deploy'.format(cephVarLibPath), ceph_osd_config)
+
+    findOsdNumCommand = 'find /var/lib/ceph/ -path "/var/lib/ceph/*/osd.*/unit.run" | wc -l'
+    out, err, code = run_command_on_host(findOsdNumCommand)
+    existOsdNums = (int(out.strip()) if out.strip().isdigit() else 0) * 20
+    logger.debug(f"start osd delay from {existOsdNums} seconds this time.")
+
+    for i in range(loopnum):
+        thisbdfs=bdfs_list[i]['bdfs']
+        osd_id= bdfs_list[i]['osd_id']
+        print(f"creating osd.{osd_id} with {thisbdfs}...")
+
+        spdk_osd_sh='''
+#!/bin/bash
+osd_id=$1
+new_uuid=$(uuidgen)
+new_key=$(ceph-authtool --gen-print-key)
+echo $new_key > tmp_keyfile
+echo '{{"cephx_secret":"'$new_key'"}}' > sc_tmp.json
+ceph --cluster ceph --name client.bootstrap-osd --keyring /var/lib/ceph/bootstrap-osd/ceph.keyring -i sc_tmp.json osd new $new_uuid $osd_id
+ceph osd tree
+
+ceph-authtool /var/lib/ceph/osd/ceph-$osd_id/keyring --create-keyring --name osd.$osd_id --add-key $new_key
+cat /var/lib/ceph/osd/ceph-$osd_id/keyring
+chown -R ceph:ceph /var/lib/ceph/osd/ceph-$osd_id/keyring
+chown -R ceph:ceph /var/lib/ceph/osd/ceph-$osd_id/
+chown -R ceph:ceph /dev/hugepages
+
+# cat /var/lib/ceph/bootstrap-osd/ceph.keyring
+ceph --cluster ceph --name client.bootstrap-osd --keyring /var/lib/ceph/bootstrap-osd/ceph.keyring mon getmap -o /var/lib/ceph/osd/ceph-$osd_id/activate.monmap
+# monmaptool --print /var/lib/ceph/osd/ceph-$osd_id/activate.monmap
+chown -R ceph:ceph /var/lib/ceph/osd/ceph-$osd_id/activate.monmap
+su - ceph -c "ceph-osd --cluster ceph --osd-objectstore bluestore --mkfs -i $osd_id --monmap /var/lib/ceph/osd/ceph-$osd_id/activate.monmap --keyfile tmp_keyfile --osdspec-affinity x18_bluestore --osd-data /var/lib/ceph/osd/ceph-$osd_id/ --osd-uuid $new_uuid --setuser ceph --setgroup ceph"
+
+# echo "create osd.$osd_id done"
+'''.format(cephVarLibPath=cephVarLibPath, fsid=ctx.fsid)
+        write_code_to_file('{}/tmp/spdk_osd.sh'.format(cephVarLibPath), spdk_osd_sh)
+        this_osd_create_command='''
+mkdir -p /var/lib/ceph/{fsid}/osd.{osd_id}/
+cp {cephVarLibPath}/tmp/ceph.conf.with.osdN.for.create.osd /var/lib/ceph/{fsid}/osd.{osd_id}/config
+
+mkdir -p /mnt/osd_{osd_id}/hugepages2M
+chmod -R 700 /mnt/osd_{osd_id}/hugepages2M
+mount -t hugetlbfs nodev /mnt/osd_{osd_id}/hugepages2M -o pagesize=2M
+
+cephadm shell \
+    -v {cephVarLibPath}/tmp/ceph_osd.keyring:/var/lib/ceph/bootstrap-osd/ceph.keyring:z \
+    -v /mnt/osd_{osd_id}/hugepages2M:/dev/hugepages:z \
+    -v /var/lib/ceph/{fsid}/osd.{osd_id}:/var/lib/ceph/osd/ceph-{osd_id}:z \
+    -v {cephVarLibPath}/tmp:/var/lib/tmp:z \
+    -c {cephVarLibPath}/tmp/ceph.conf.with.osdN.for.create.osd \
+    sh /var/lib/tmp/spdk_osd.sh {osd_id}
+'''.format(cephVarLibPath=cephVarLibPath, fsid=ctx.fsid, osd_id=osd_id)
+        out = subprocess.run(this_osd_create_command,  shell=True, text=True, capture_output=True)
+        if out.returncode != 0:
+            print(f'create osd err! errcode: {out.returncode}')
+            print(f'create osd out content:{out.stdout}')
+            print(f'create osd err content:{out.stderr}')
+            return -2
+        else:
+            logger.debug(out.stderr)
+        logger.debug(f"create osd.{osd_id} with {thisbdfs} done")
+
+        l2f = 'true' if ctx.extra_log == True else 'false' # save log only got --extra-log or -vv
+        delay = (i + 1) * 20 + existOsdNums
+        unit_run='''
+sleep {delay}
+set -e
+# sh {cephVarLibPath}/tmp/created_hugepage.sh
+mkdir -p /mnt/osd_{osd_id}/hugepages2M
+chmod -R 700 /mnt/osd_{osd_id}/hugepages2M
+mount -t hugetlbfs nodev /mnt/osd_{osd_id}/hugepages2M -o pagesize=2M
+
+/usr/bin/podman run --rm --ipc=host --stop-signal=SIGTERM --net=host --entrypoint /usr/bin/ceph-osd \
+    --privileged --group-add=disk --init --name ceph-{fsid}-osd-{osd_id} --pids-limit=-1 \
+    -d --log-driver journald --conmon-pidfile /run/ceph-{fsid}@osd.{osd_id}.service-pid \
+    --cidfile /run/ceph-{fsid}@osd.{osd_id}.service-cid --cgroups=split \
+    -e CONTAINER_IMAGE={spdk_image_withhash} -e NODE_NAME=ceph1 -e CEPH_USE_RANDOM_NONCE=1 \
+    -e TCMALLOC_MAX_TOTAL_THREAD_CACHE_BYTES=134217728 \
+    -e LD_PRELOAD=/usr/lib64/libksal_libc.so \
+    -v /var/run/ceph/{fsid}:/var/run/ceph:z -v /var/log/ceph/{fsid}:/var/log/ceph:z \
+    -v /var/lib/ceph/{fsid}/crash:/var/lib/ceph/crash:z -v /run/systemd/journal:/run/systemd/journal \
+    -v /var/lib/ceph/{fsid}/osd.{osd_id}:/var/lib/ceph/osd/ceph-{osd_id}:z \
+    -v /var/lib/ceph/{fsid}/osd.{osd_id}/config:/etc/ceph/ceph.conf:z \
+    -v /dev:/dev \
+    -v /run/udev:/run/udev -v /sys:/sys -v /run/lvm:/run/lvm -v /run/lock/lvm:/run/lock/lvm \
+    -v /mnt/osd_{osd_id}/hugepages2M:/dev/hugepages \
+    -v /etc/hosts:/etc/hosts:ro -u ceph {spdk_image_withhash} -n osd.{osd_id} -f --setuser ceph --setgroup ceph \
+    --default-log-to-file={l2f} --default-log-to-journald=true --default-log-to-stderr=false  \
+    # --debug-osd=15 --debug-ms=2 --debug-bluestore=15 --debug-bdev=20
+'''.format(cephVarLibPath=cephVarLibPath, fsid=ctx.fsid, spdk_image_withhash=imageName, osd_id=osd_id,  l2f=l2f, delay=delay)
+        write_code_to_file('{}/osd.{}/unit.run'.format(cephVarLibPath, osd_id), unit_run)
+
+        unit_stop='''
+set -e
+! /usr/bin/podman inspect ceph-{fsid}-osd-{osd_id} &>/dev/null || /usr/bin/podman stop ceph-{fsid}-osd-{osd_id}
+umount /mnt/osd_{osd_id}/hugepages2M
+'''.format(fsid=ctx.fsid, spdk_image_withhash=imageName, osd_id=osd_id)
+        write_code_to_file('{}/osd.{}/unit.stop'.format(cephVarLibPath, osd_id), unit_stop)
