+            __builtin_prefetch(pos + PREFETCH_LONG_LENGTH + CACHELINE_SIZE * 2, 0, 2);
+            __builtin_prefetch(pos + PREFETCH_NORMAL_LENGTH + CACHELINE_SIZE * 3, 0, 0);
