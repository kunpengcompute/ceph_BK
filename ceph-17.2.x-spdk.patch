+        print('run_command_on_host error:', err)
+    else:
+        print('run_command_on_host done:', out)
+
+    return 0
+
+# exec command on target host
+# @params [str]  command:  shell command
+# @params [str]  hostname: which host to run command. default is '' means localhost
+# @params [out,err,code]   code == 0 means success
+def run_command_on_host(command, hostname = '', async_mode: bool = False):
+    this_osd_command = command
+    if hostname:
+        this_osd_command = '''
+ssh -T root@{hostname} << EOF
+{command}
+EOF
+'''.format(hostname=hostname, command=command)
+    if async_mode:
+        process = subprocess.Popen(this_osd_command, shell=True, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
+        return process
+    else:
+        out = subprocess.run(this_osd_command,  shell=True, text=True, capture_output=True)
+        return out.stdout,out.stderr,out.returncode
