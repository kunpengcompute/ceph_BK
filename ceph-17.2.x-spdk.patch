+        write_code_to_file('{}/osd.{}/unit.image'.format(cephVarLibPath, osd_id), imageName)
+    print('init done')
+
+    return 0
+
+# get bdfs
+# @params [string]  userInputBdfsStr     string format bdfs
+# @params [string]  configFile           yaml bdfs
+# @returns [array]  example: [{'osd_id': 0, 'bdfs': '0000:82:00.0'}, {'osd_id': 1, 'bdfs': '0000:83:00.0'}]
+def getbdfs(ctx, userInputBdfsStr, configFile):
+    if configFile:
+        if not os.path.exists(configFile):
+            print('the yaml path does not exist!')
+            sys.exit(100006)
+        try:
+            with open(configFile, 'r') as f:
+                out = yaml.safe_load(f)
+                logger.debug(f"yaml load data:{out}")
+                if isinstance(out, list):
+                    validate_bdfs(ctx, out)
+                    return out
+                print(f"YAML file {configFile} data error: the yaml need a list format")
+                sys.exit(100007)
+        except yaml.YAMLError as e:
+            print(f"YAML file {configFile} error: please check your yaml file content!")
+            sys.exit(100001)
+        except Exception as e:
+            print(f"Unexpected error: please check your yaml file content! err:{e}")
+            sys.exit(100005)
+
+    if userInputBdfsStr:
+        arr = userInputBdfsStr.split('-')
+        osd_exist_idx = getOneAvaliableOsdid()
+        res = [{'osd_id': osd_exist_idx + i, 'bdfs': part} for i, part in enumerate(arr)]
+        validate_bdfs(ctx, res)
+        return res
+
+    command = "cephadm shell sh /var/lib/ceph/spdk_lib/scripts/setup.sh status 2>/dev/null | grep 'uio' | awk '{print $2}'"
+    out = subprocess.run(command,  shell=True, text=True, capture_output=True)
+    bdfs = [line.strip() for line in out.stdout.strip().splitlines()]
+    osd_exist_idx = getOneAvaliableOsdid()
+    res = [{'osd_id': osd_exist_idx + i, 'bdfs': part} for i, part in enumerate(bdfs)]
+    validate_bdfs(ctx, res)
+    return res
+
+def validate_bdfs(ctx, bdfsarr):
+    existOsdIds = []
+    avaliableDevices = []
+
+    getOsdIdsCommand = "cephadm shell ceph osd tree 2>/dev/null | grep 'osd.'|awk '{print $1}'"
+    getAvaliDevCommand = "cephadm shell sh /var/lib/ceph/spdk_lib/scripts/setup.sh status 2>/dev/null | grep 'uio' | awk '{print $2}'"
+
+    out, err, code = run_command_on_host(getOsdIdsCommand)
+    existOsdIds = [int(line.strip()) for line in out.strip().splitlines()]
+
+    out, err, code = run_command_on_host(getAvaliDevCommand)
+    avaliableDevices = [line.strip() for line in out.strip().splitlines()]
+
+    logger.debug(f'validate_bdfs:data in vailding is {bdfsarr}')
+    logger.debug(f'validate_bdfs:existOsdIds is {existOsdIds}')
+    logger.debug(f'validate_bdfs:avaliableDevices is {avaliableDevices}')
+
+    if len(existOsdIds) > 0:
+        for osdid in existOsdIds:
+            getOsdDeviceCommand = "ls -l /var/lib/ceph/{fsid}/osd.{osdid}/block | awk -F'traddr:' '{{print $2}}' | awk '{{print $1}}' | tr -d '\n'".format(fsid=ctx.fsid, osdid=osdid)
+            out, err, code = run_command_on_host(getOsdDeviceCommand)
+            logger.debug(f'validate_bdfs:device {out} is used by osd.{osdid}')
+            if out and out.strip():
+                avaliableDevices = [item for item in avaliableDevices if out not in item]
+        logger.debug(f'validate_bdfs:avaliableDevices except osd used is {avaliableDevices}')
+
+    for item in bdfsarr:
+        if 'bdfs' not in item or 'osd_id' not in item:
+            print(f"yaml format error: Both 'osd_id' and 'bdfs' should  be provided at same time in yaml content!")
+            sys.exit(10014)
+        this_bdfs=item['bdfs']
+        this_osd_id= item['osd_id']
+        if this_osd_id in existOsdIds:
+            print(f"osd id error: osd.{this_osd_id} has been used! please change yaml content!")
+            sys.exit(10012)
+        if this_bdfs not in avaliableDevices:
+            print(f"bdfs error: device {this_bdfs} did not driver by uio or has been used. can not choose this device for deploy!")
+            sys.exit(10013)
+
+    return 0
+
+def getOneAvaliableOsdid()->int:
+    command = "cephadm shell ceph osd tree 2>/dev/null | grep 'osd.'|awk '{print $1}'"
+    out = subprocess.run(command,  shell=True, text=True, capture_output=True)
+    if out.returncode != 0:
+        # raise RuntimeError("Can not get OSD IDs.")
+        return 0
+    osd_ids = [int(line.strip()) for line in out.stdout.strip().splitlines()]
+    if not osd_ids:
+        return 0
+    if len(osd_ids) == 0:
+        return 0
+    osd_ids.sort()
+    return osd_ids[-1] + 1
+
+def write_code_to_file(filepath, code):
+    try:
+        os.makedirs(os.path.dirname(filepath + '.new'), exist_ok=True)
+        with open(filepath + '.new', 'w') as f:
+            f.write(code)
+            os.rename(filepath + '.new',
+                filepath)
+    except PermissionError:
+        print(f"Error: Permission denied. please check the permission on the '{filepath}' path.")
+        sys.exit(100021)
+    except IOError as e:
+        print(f"Error writing file '{filepath}': {e}")
+        sys.exit(100022)
+    except Exception as e:
+        print(f"Unexpected error when writing file '{filepath}': {e}")
+        sys.exit(100023)
+    return 0
+
+def read_file_content(filepath: str) -> str:
+    try:
+        with open(filepath, 'r') as file:
+            content = file.read()
+        return content
+    except FileNotFoundError:
+        print(f"Error: The file at path '{filepath}' was not found.")
+        sys.exit(100011)
+    except IOError as e:
+        print(f"Error reading file '{filepath}': {e}")
+        sys.exit(100012)
+    except Exception as e:
+        print(f"Unexpected error when reading file '{filepath}': {e}")
+        sys.exit(100013)
+    return ""
+
+def spdk_osd_deploy(ctx,cephVarLibPath ,fsid):
+    isExist = False
+    if os.path.exists(cephVarLibPath):
+        for i in os.listdir(cephVarLibPath):
+            if '.' in i and  'osd' in i:
+                isExist = True
+                name = i
+                (daemon_type, daemon_id) = i.split('.', 1)
+                unit_name = get_unit_name(fsid,
+                                            daemon_type,
+                                            daemon_id)
+                print(f'start service: {unit_name}')
+                call_throws(ctx, ['systemctl', 'enable', unit_name])
+                run_command_on_host(f'systemctl start {unit_name}', '', True)
+
+    if not isExist:
+        print('no osd service to deploy! please exec `cephadm spdkosd init` first!')
+        return -1
+
+    refreshStatusCommand = 'cephadm shell ceph orch ls --refresh'
+    out, err, code = run_command_on_host(refreshStatusCommand)
+    if code != 0:
+        print('orch ls refresh error:', err)
+
+    print('All OSDs above are scheduled to start!')
+    return 0
+
+def test_run_command_on_host():
+    testcommand = '''
+echo "this command is from other host" > /home/tmp.log
+echo "this command is to local host" >> /home/tmp.log
+'''
+    testcommand = 'cephadm shell ceph auth get client.bootstrap-osd'
+    out, err, code = run_command_on_host(testcommand)
